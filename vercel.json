{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-learning-assistant-aunn.onrender.com/api/:path*"
    },
    {
      "source": "/((?!_\\/backend|api).*)",
      "destination": "/index.html"
    }
  ]
}